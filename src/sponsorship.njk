<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lenis@1/dist/lenis.min.js"></script>
{% raw %}
    <script>
        const advParseRoundEnd = (value) => new Date(value + 'T23:59:59');

        const advMarkPastRounds = () => {
            const now = new Date();
            document.querySelectorAll('.adv-stop[data-end]').forEach((stop) => {
                const ended = advParseRoundEnd(stop.dataset.end);
                if (ended.getTime() < now.getTime()) {
                    stop.classList.add('adv-stop--past');
                    const tag = stop.querySelector('.adv-stop-tag');
                    if (tag && tag.textContent.trim() === 'Open') {
                        tag.textContent = 'Passed';
                    }
                }
            });
        };

        advMarkPastRounds();

        /* ── Live "today" projection + growth-chart draw-in ──────── */
        const advPrefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        /* Real figures: 149 active players at launch (24 May 2026)
           rising to 558 on 31 May 2026 - about 4x in seven days.
           The derived daily growth factor is (558/149)^(1/7). */
        const advBaselineCount = 558;
        const advDailyGrowthFactor = Math.pow(558 / 149, 1 / 7);
        const advProjectionBaseTime = new Date('2026-05-31T00:00:00').getTime();
        const advMillisPerDay = 24 * 60 * 60 * 1000;

        const advProjectedCount = (atTime) => {
            const fractionalDaysSinceBase = (atTime - advProjectionBaseTime) / advMillisPerDay;
            const projected = advBaselineCount * Math.pow(advDailyGrowthFactor, fractionalDaysSinceBase);
            return Math.max(advBaselineCount, Math.round(projected));
        };

        const advTodayLabel = document.querySelector('.adv-chart-today');
        const advLiveStat = document.querySelector('.adv-stat-live');

        const advFormatCount = (count) => count.toLocaleString('en-GB');

        const advRenderLiveCount = (count) => {
            const formatted = advFormatCount(count);
            if (advTodayLabel) {
                advTodayLabel.textContent = formatted;
            }
            if (advLiveStat) {
                advLiveStat.textContent = formatted;
            }
        };

        /* Gentle real-time tick: re-derive from the current clock every
           few seconds so the figure keeps pace with the ~20.8%/day rate. */
        const advStartLiveTicker = () => {
            const advTickIntervalMs = 4000;
            window.setInterval(() => {
                advRenderLiveCount(advProjectedCount(Date.now()));
            }, advTickIntervalMs);
        };

        /* Count up from the launch figure to the live projection. Runs in step
           with the line drawing so the number climbs at the head of the line,
           landing on the live figure as the line reaches the today point. The
           count starts low (149) so it visibly climbs through the real week. */
        const advCountUpToLive = (targetCount, countUpDurationMs) => {
            if (advPrefersReducedMotion) {
                advRenderLiveCount(targetCount);
                advStartLiveTicker();
                return;
            }
            const startCount = 149;
            const durationMs = countUpDurationMs || 1100;
            let animationStartTime = null;

            const advStep = (timestamp) => {
                if (animationStartTime === null) {
                    animationStartTime = timestamp;
                }
                const elapsed = timestamp - animationStartTime;
                const progress = Math.min(1, elapsed / durationMs);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = Math.round(startCount + (targetCount - startCount) * eased);
                advRenderLiveCount(current);
                if (progress < 1) {
                    window.requestAnimationFrame(advStep);
                    return;
                }
                advStartLiveTicker();
            };

            window.requestAnimationFrame(advStep);
        };

        const advSolidDrawDurationMs = 1200;

        /* Each real point keyed to the fraction of the solid line drawn when the
           head reaches it (launch 0, 279 ~0.43, 465 ~0.72, today 1.0), so its dot
           and any label pop in just as the line arrives. */
        const advPointReveals = [
            { selector: '.adv-chart-dot-1, .adv-chart-label-1, .adv-chart-axislabel', fraction: 0 },
            { selector: '.adv-chart-dot-mid', fraction: 0.43, index: 0 },
            { selector: '.adv-chart-dot-mid', fraction: 0.72, index: 1 },
            { selector: '.adv-chart-dot-2, .adv-chart-label-2', fraction: 1 }
        ];

        const advPopElements = (chartCard, selector, singleIndex) => {
            const matches = chartCard.querySelectorAll(selector);
            if (typeof singleIndex === 'number') {
                const target = matches[singleIndex];
                if (target) {
                    target.classList.add('adv-chart-pop');
                }
                return;
            }
            matches.forEach((element) => {
                element.classList.add('adv-chart-pop');
            });
        };

        /* Land the chart in its complete drawn state immediately, with no
           transitions - used for reduced-motion and as the safety fallback
           so the chart is never left half-hidden. */
        const advShowChartFinalState = (chartCard) => {
            const solidLine = chartCard.querySelector('.adv-chart-line');
            if (solidLine) {
                solidLine.style.transition = 'none';
                solidLine.style.strokeDasharray = 'none';
                solidLine.style.strokeDashoffset = '0';
            }
            chartCard.querySelectorAll('.adv-chart-dashed').forEach((dashedPath) => {
                dashedPath.style.transition = 'none';
                dashedPath.style.opacity = '0.55';
            });
            chartCard.classList.add('adv-chart-drawn');
            advCountUpToLive(advProjectedCount(Date.now()));
        };

        const advAnimateChart = (chartCard) => {
            if (advPrefersReducedMotion) {
                advShowChartFinalState(chartCard);
                return;
            }

            const solidLine = chartCard.querySelector('.adv-chart-line');
            const dashedSegments = chartCard.querySelectorAll('.adv-chart-dashed');
            const areaFill = chartCard.querySelector('.adv-chart-area');

            if (areaFill) {
                /* The area grows in alongside the line drawing. */
                areaFill.style.transition = 'opacity ' + advSolidDrawDurationMs + 'ms var(--ease-out)';
                window.requestAnimationFrame(() => {
                    areaFill.style.opacity = '1';
                });
            }

            const advStartDraw = () => {
                if (solidLine) {
                    solidLine.style.transition = 'stroke-dashoffset ' + advSolidDrawDurationMs + 'ms var(--ease-out)';
                    solidLine.style.strokeDashoffset = '0';
                }

                /* Count the head figure up in lockstep with the line drawing. */
                advCountUpToLive(advProjectedCount(Date.now()), advSolidDrawDurationMs);

                /* Pop each real point in as the drawing head reaches it. */
                advPointReveals.forEach((reveal) => {
                    window.setTimeout(() => {
                        advPopElements(chartCard, reveal.selector, reveal.index);
                    }, reveal.fraction * advSolidDrawDurationMs);
                });

                /* Once the solid line is drawn, the dashed projection fades in,
                   then the Worlds endpoint pops at the head of the curve. */
                dashedSegments.forEach((dashedPath, segmentIndex) => {
                    dashedPath.style.opacity = '0';
                    window.setTimeout(() => {
                        dashedPath.style.opacity = '0.55';
                    }, advSolidDrawDurationMs + segmentIndex * 160);
                });

                window.setTimeout(() => {
                    advPopElements(chartCard, '.adv-chart-dot-3, .adv-chart-label-3');
                    chartCard.classList.add('adv-chart-drawn');
                }, advSolidDrawDurationMs + dashedSegments.length * 160 + 200);
            };

            if (solidLine) {
                const lineLength = solidLine.getTotalLength();
                solidLine.style.transition = 'none';
                solidLine.style.strokeDasharray = lineLength + ' ' + lineLength;
                solidLine.style.strokeDashoffset = lineLength;
                /* Force a reflow so the starting offset is committed, then a
                   double rAF before starting the draw - a single frame can get
                   batched with the initial assignment and snap instead. */
                solidLine.getBoundingClientRect();
                window.requestAnimationFrame(() => {
                    window.requestAnimationFrame(advStartDraw);
                });
            } else {
                advStartDraw();
            }
        };

        const advChartCard = document.querySelector('.adv-chart-card');

        if (advChartCard) {
            /* Arm the card so the draw-in elements start hidden. If the script
               below never runs the elements stay visible (the hiding rules only
               apply while .adv-chart-armed is present). */
            advChartCard.classList.add('adv-chart-armed');

            if (advPrefersReducedMotion) {
                advShowChartFinalState(advChartCard);
            } else {
                let advChartHasAnimated = false;
                const advRunChartOnce = () => {
                    if (advChartHasAnimated) {
                        return;
                    }
                    advChartHasAnimated = true;
                    advAnimateChart(advChartCard);
                };

                const advChartIsInViewport = () => {
                    const bounds = advChartCard.getBoundingClientRect();
                    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
                    return bounds.top < viewportHeight && bounds.bottom > 0;
                };

                if ('IntersectionObserver' in window) {
                    const advChartObserver = new IntersectionObserver(
                        (entries, observerInstance) => {
                            entries.forEach((entry) => {
                                if (entry.isIntersecting) {
                                    advRunChartOnce();
                                    observerInstance.unobserve(entry.target);
                                }
                            });
                        },
                        /* A low threshold plus a negative bottom margin fires for a
                           chart already on screen at load and for one scrolled to. */
                        { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
                    );
                    advChartObserver.observe(advChartCard);

                    /* Safety net: if the chart is on screen but the observer has not
                       fired within a second (already-visible edge cases, layout
                       quirks), draw anyway so it is never left half-hidden. A chart
                       still below the fold is left to the observer. */
                    window.setTimeout(() => {
                        if (!advChartHasAnimated && advChartIsInViewport()) {
                            advRunChartOnce();
                        }
                    }, 1000);
                } else {
                    /* No observer support: reveal the full chart up front. */
                    advShowChartFinalState(advChartCard);
                    advChartHasAnimated = true;
                }
            }
        }
    </script>
    <script>
        /* ── Scroll demo: pick → spotlight → result (full-bleed) ─────
           A pinned, scroll-scrubbed takeover built on GSAP ScrollTrigger,
           with Lenis driving smooth scroll. Three scenes scale and
           cross-fade over a shifting background. Skipped entirely for
           reduced motion or if the libraries fail to load, leaving the
           section in its static beat-1 state (picks scene, first caption). */
        const advInitScrollDemo = () => {
            const section = document.querySelector('.adv-sd');
            if (!section || !window.gsap || !window.ScrollTrigger) {
                return;
            }
            if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                return;
            }

            gsap.registerPlugin(ScrollTrigger);

            if (window.Lenis) {
                const lenis = new Lenis({ duration: 1.1, smoothWheel: true });
                lenis.on('scroll', ScrollTrigger.update);
                gsap.ticker.add((time) => lenis.raf(time * 1000));
                gsap.ticker.lagSmoothing(0);
            }

            const stage = section.querySelector('.adv-sd-stage');
            const bgPick = section.querySelector('.adv-sd-bg--1');
            const bgSpot = section.querySelector('.adv-sd-bg--2');
            const bgBoard = section.querySelector('.adv-sd-bg--3');
            const picks = section.querySelectorAll('.adv-sd-pick');
            const captions = section.querySelectorAll('.adv-sd-caption');
            const dots = section.querySelectorAll('.adv-sd-dot');
            const scenePredict = section.querySelector('.adv-sd-scene--predict');
            const sceneSpot = section.querySelector('.adv-sd-scene--spot');
            const sceneBoard = section.querySelector('.adv-sd-scene--board');
            const rows = Array.from(section.querySelectorAll('.adv-sd-row'));
            const youRow = section.querySelector('.adv-sd-row--you');
            const youPts = youRow ? youRow.querySelector('.adv-sd-row-pts') : null;
            const boardBody = section.querySelector('.adv-sd-board-body');

            /* Read the slot height straight from the CSS custom property so the
               climb distance matches the badge gutter exactly - getBoundingClientRect
               would return a scaled value while the scene is mid-transition. As a
               function with invalidateOnRefresh it also stays correct across the
               responsive breakpoint. */
            const rowHeight = () => {
                const value = parseFloat(getComputedStyle(boardBody).getPropertyValue('--row-h'));
                return Number.isFinite(value) ? value : 52;
            };

            gsap.set([bgSpot, bgBoard], { opacity: 0 });
            gsap.set(bgPick, { opacity: 1 });
            gsap.set(scenePredict, { opacity: 1, scale: 1, y: 0 });
            gsap.set(sceneSpot, { opacity: 0, scale: 0.9, y: 24 });
            gsap.set(sceneBoard, { opacity: 0, scale: 0.96 });
            gsap.set(picks, { opacity: 0, y: 26 });
            gsap.set(captions[0], { opacity: 1, y: 0 });
            gsap.set([captions[1], captions[2]], { opacity: 0, y: 18 });

            const pointsState = { value: youPts ? Number(youPts.dataset.from) : 0 };
            const pointsTarget = youPts ? Number(youPts.dataset.to) : 0;

            /* Light the dot for whichever caption is currently most visible, so
               the indicator always tracks the live phase regardless of timing. */
            const updateDots = () => {
                let activeIndex = 0;
                let highestOpacity = -1;
                captions.forEach((caption, index) => {
                    const opacity = Number(gsap.getProperty(caption, 'opacity'));
                    if (opacity > highestOpacity) {
                        highestOpacity = opacity;
                        activeIndex = index;
                    }
                });
                dots.forEach((dot, index) => dot.classList.toggle('is-active', index === activeIndex));
            };

            /* A higher scrub value lets the animation glide toward the scroll
               position rather than tracking it 1:1, which softens the pin catch
               and makes each phase flow into the next. */
            const timeline = gsap.timeline({
                defaults: { ease: 'power1.inOut' },
                scrollTrigger: {
                    trigger: section,
                    start: 'top top',
                    end: '+=2800',
                    pin: stage,
                    scrub: 1.5,
                    anticipatePin: 1,
                    invalidateOnRefresh: true,
                    onUpdate: updateDots
                }
            });

            /* Beat 1 — each team drops in on scroll, one after another */
            timeline.to(picks, { opacity: 1, y: 0, stagger: 0.5, duration: 0.9, ease: 'back.out(1.4)' }, 0);

            /* Beat 1 → 2 — picks recede as the spotlight rises and the sky darkens */
            timeline.to(captions[0], { opacity: 0, y: -18, duration: 0.6 }, 2.6);
            timeline.to(captions[1], { opacity: 1, y: 0, duration: 0.6 }, 3.0);
            timeline.to(bgPick, { opacity: 0, duration: 1.1 }, 2.6);
            timeline.to(bgSpot, { opacity: 1, duration: 1.1 }, 2.6);
            timeline.to(scenePredict, { opacity: 0, scale: 0.82, y: -12, duration: 1.0 }, 2.7);
            timeline.to(sceneSpot, { opacity: 1, scale: 1, y: 0, duration: 1.1, ease: 'back.out(1.2)' }, 2.9);

            /* A gentle drift while the spotlight holds, so nothing sits dead still */
            timeline.to(sceneSpot, { scale: 1.04, duration: 1.0, ease: 'sine.inOut' }, 4.1);

            /* Beat 2 → 3 — spotlight lifts away, the board scales in, sky brightens */
            timeline.to(captions[1], { opacity: 0, y: -18, duration: 0.6 }, 5.3);
            timeline.to(captions[2], { opacity: 1, y: 0, duration: 0.6 }, 5.7);
            timeline.to(bgSpot, { opacity: 0, duration: 1.1 }, 5.3);
            timeline.to(bgBoard, { opacity: 1, duration: 1.1 }, 5.3);
            timeline.to(sceneSpot, { opacity: 0, scale: 1.14, duration: 0.9 }, 5.3);
            timeline.to(sceneBoard, { opacity: 1, scale: 1, duration: 1.0 }, 5.7);

            /* Beat 3 — the climb: rows above shift down, your row rises to the top */
            const climbAt = 6.5;
            rows.forEach((row) => {
                if (Number(row.dataset.start) < 4) {
                    timeline.to(row, { y: () => rowHeight(), duration: 2.0, ease: 'power2.inOut' }, climbAt);
                }
            });
            if (youRow) {
                timeline.to(youRow, { y: () => -4 * rowHeight(), duration: 2.0, ease: 'power2.inOut' }, climbAt);
            }
            if (youPts) {
                timeline.to(pointsState, {
                    value: pointsTarget,
                    duration: 2.0,
                    ease: 'power1.out',
                    onUpdate: () => { youPts.textContent = Math.round(pointsState.value); }
                }, climbAt);
            }

            /* Tail hold so the sequence does not end the instant the board lands */
            timeline.to({}, { duration: 0.8 }, 8.9);

            updateDots();
        };

        window.addEventListener('load', advInitScrollDemo);
    </script>
    <script>
        /* Placement explorer: tabs swap the mockup. It auto-advances every 10s
           (the active tab's progress bar IS the timer); any click hands control
           to the visitor and stops the carousel for good. */
        (function () {
            const picker = document.querySelector('[data-pick]');
            if (!picker) {
                return;
            }
            const tabs = Array.from(picker.querySelectorAll('[data-pick-tab]'));
            const panels = picker.querySelectorAll('[data-pick-panel]');
            if (tabs.length < 2) {
                return;
            }

            const activate = (key) => {
                tabs.forEach((tab) => {
                    const isActive = tab.dataset.pickTab === key;
                    tab.classList.toggle('is-active', isActive);
                    tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
                });
                panels.forEach((panel) => {
                    panel.classList.toggle('is-active', panel.dataset.pickPanel === key);
                });
            };

            const activeIndex = () => tabs.findIndex((tab) => tab.classList.contains('is-active'));

            picker.addEventListener('animationend', (event) => {
                if (event.animationName !== 'advPickProgress' || !picker.classList.contains('is-autoplay')) {
                    return;
                }
                const next = (activeIndex() + 1) % tabs.length;
                activate(tabs[next].dataset.pickTab);
            });

            tabs.forEach((tab) => {
                tab.addEventListener('click', () => {
                    picker.classList.remove('is-autoplay');
                    activate(tab.dataset.pickTab);
                });
            });

            if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
                picker.classList.add('is-autoplay');
            }
        })();
    </script>
